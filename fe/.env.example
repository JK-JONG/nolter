# ── Supabase 실시간 백엔드 ───────────────────────────────
# 비워두면 실시간 협업이 꺼지고 혼자(로컬 전용) 모드로 동작한다.
# 두 값 모두 브라우저에 공개되는 public 값이라 노출돼도 안전하다.
# (실제 보호는 고엔트로피 "방 코드" + DB의 SECURITY DEFINER RPC 가 담당)
#
# 같은 Supabase 프로젝트를 워크아웃 트래커와 공유해도 된다(테이블이 다름).
# Supabase 대시보드 → Settings → API:
#   - Project URL            → VITE_SUPABASE_URL
#   - anon / publishable key → VITE_SUPABASE_ANON_KEY
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ── 관리자 식별 (선택) ───────────────────────────────────
# 닉네임 + 비밀번호 둘 다 일치할 때 admin 모드 활성:
#   · 상단 ⚙️ 설정 메뉴 노출
#   · 새 모임방 만들기 권한 (일반 사용자에게는 숨김)
# 둘 다 비워두면 admin 기능 비활성.
VITE_ADMIN_NICKNAME=Olaf
VITE_ADMIN_PASSWORD=

# ── 배포 base 경로 (선택) ────────────────────────────────
# GitHub Pages 는 워크플로우가 /<repo>/ 를 자동 주입하므로 보통 비워둔다.
# 루트 도메인(Cloudflare Pages 등)에 올릴 땐 VITE_BASE=/ 로 빌드.
# VITE_BASE=/
